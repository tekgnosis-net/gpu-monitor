{#
    Daily/weekly/monthly report template.

    Phase 6b of the v1.0.0 overhaul. One template parameterized by
    {{ range_label }} ("24 hours" / "7 days" / "30 days") and
    {{ gpus }} (list of per-GPU sections with stats + chart CIDs).

    Design constraints:
      * This template is rendered by premailer after Jinja expansion,
        so <style> blocks in the <head> are inlined onto every matching
        element automatically. Write CSS in the <style> block; don't
        reach for `style="..."` attributes unless you're overriding
        an inlined rule.
      * Image references use `<img src="cid:chart_...">` — the CID
        strings must match the Content-ID attached to each PNG in
        render.py's attach_charts() call. If they drift, Gmail shows
        broken-image icons.
      * Gmail and Outlook both strip unrecognized HTML tags and
        rewrite CSS properties. Keep the markup to standard block
        and inline elements (div/span/h1-h3/p/table). No flexbox,
        no grid, no custom elements.
      * The footer links NEVER go to the user's own instance because
        this is an email — embedding a LAN URL would be broken for
        any recipient who isn't on the LAN. Footer is plain-text
        attribution only.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ report_title }}</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f5f5f7;
      font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #1d1d1f;
      line-height: 1.4;
    }
    .wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 32px 24px;
    }
    .header {
      background: #ffffff;
      border-radius: 14px;
      padding: 24px 28px;
      margin-bottom: 20px;
      border: 1px solid rgba(60, 60, 67, 0.1);
    }
    .header h1 {
      margin: 0 0 4px 0;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .header .subtitle {
      color: #6e6e73;
      font-size: 15px;
    }
    .aggregate {
      display: table;
      width: 100%;
      margin-top: 16px;
      border-collapse: separate;
      border-spacing: 8px 0;
    }
    .aggregate-tile {
      display: table-cell;
      background: #fafafa;
      border-radius: 10px;
      padding: 12px 16px;
      text-align: center;
      vertical-align: top;
    }
    .aggregate-tile .label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #6e6e73;
      margin-bottom: 4px;
    }
    .aggregate-tile .value {
      font-size: 22px;
      font-weight: 600;
      color: #1d1d1f;
    }
    .aggregate-tile .unit {
      font-size: 13px;
      font-weight: 400;
      color: #6e6e73;
      margin-left: 2px;
    }
    .gpu-card {
      background: #ffffff;
      border-radius: 14px;
      padding: 20px 28px 24px 28px;
      margin-bottom: 16px;
      border: 1px solid rgba(60, 60, 67, 0.1);
    }
    .gpu-card h2 {
      margin: 0 0 4px 0;
      font-size: 20px;
      font-weight: 600;
    }
    .gpu-card .meta {
      color: #6e6e73;
      font-size: 13px;
      margin-bottom: 16px;
    }
    .gpu-stats {
      display: table;
      width: 100%;
      margin: 16px 0;
      border-collapse: collapse;
    }
    .gpu-stats .stat-row {
      display: table-row;
    }
    .gpu-stats .stat-row .label,
    .gpu-stats .stat-row .value {
      display: table-cell;
      padding: 6px 0;
      border-bottom: 1px solid rgba(60, 60, 67, 0.08);
      font-size: 14px;
    }
    .gpu-stats .stat-row .label {
      color: #6e6e73;
    }
    .gpu-stats .stat-row .value {
      text-align: right;
      color: #1d1d1f;
      font-weight: 500;
    }
    .chart {
      margin: 12px 0;
      text-align: center;
    }
    .chart img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
    }
    .footer {
      color: #6e6e73;
      font-size: 12px;
      text-align: center;
      margin-top: 24px;
      padding: 16px;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="header">
      <h1>{{ report_title }}</h1>
      <div class="subtitle">
        {{ range_label }} of GPU telemetry &middot;
        {{ generated_at }}
      </div>
      {% if aggregate %}
      <div class="aggregate">
        <div class="aggregate-tile">
          <div class="label">Total energy</div>
          <div class="value">
            {{ aggregate.energy_value }}<span class="unit">{{ aggregate.energy_unit }}</span>
          </div>
        </div>
        <div class="aggregate-tile">
          <div class="label">Peak power</div>
          <div class="value">
            {{ aggregate.peak_w|round(1) }}<span class="unit">W</span>
          </div>
        </div>
        <div class="aggregate-tile">
          <div class="label">Estimated cost</div>
          <div class="value">{{ aggregate.cost_display }}</div>
        </div>
      </div>
      {% endif %}
    </div>

    {% for gpu in gpus %}
    <div class="gpu-card">
      <h2>{{ gpu.name }}</h2>
      <div class="meta">GPU {{ gpu.index }} &middot; {{ gpu.samples }} samples</div>

      <div class="gpu-stats">
        <div class="stat-row">
          <div class="label">Temperature (min / avg / max)</div>
          <div class="value">{{ gpu.temp_min }} / {{ gpu.temp_avg }} / {{ gpu.temp_max }} &deg;C</div>
        </div>
        <div class="stat-row">
          <div class="label">Utilization (avg / max)</div>
          <div class="value">{{ gpu.util_avg }}% / {{ gpu.util_max }}%</div>
        </div>
        <div class="stat-row">
          <div class="label">Energy</div>
          <div class="value">{{ gpu.energy_value }} {{ gpu.energy_unit }}</div>
        </div>
        <div class="stat-row">
          <div class="label">Peak / average power</div>
          <div class="value">{{ gpu.peak_w|round(1) }} W / {{ gpu.avg_w|round(1) }} W</div>
        </div>
      </div>

      {% if gpu.chart_cids %}
      <div class="chart">
        <img src="cid:{{ gpu.chart_cids.temp }}"
             alt="Temperature trend for GPU {{ gpu.index }}">
      </div>
      <div class="chart">
        <img src="cid:{{ gpu.chart_cids.power }}"
             alt="Power trend for GPU {{ gpu.index }}">
      </div>
      {% endif %}
    </div>
    {% endfor %}

    <div class="footer">
      Sent by GPU Monitor v{{ version }} &middot;
      Built with love by Tekgnosis
    </div>
  </div>
</body>
</html>
