# Logs and data
data/
*.log
logs/*
!logs/.gitkeep

# Environment
.env

# Docker
.docker/

# Editor files

.idea/
*.swp

# System files
.DS_Store
Thumbs.db

# In .gitignore
history/*
!history/.gitkeep
CLAUDE.md

# Session-local tooling state (Claude Code remember hook, runtime state, etc.)
.remember/
.claude/

# Python bytecode caches — pytest / imports generate these in-tree.
__pycache__/
*.py[cod]
*.pyo

# Local dev artifacts from Playwright MCP smoke testing —
# screenshots + MCP runtime state live at the repo root during
# iterative UX work and should never be committed.
.playwright-mcp/
/*.png

